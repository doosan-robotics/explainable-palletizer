# ---------------------------------------------------------------------------
# dr-ai-palletizer app-server environment variables
# Copy to .env and adjust as needed: cp app/.env.example app/.env
# ---------------------------------------------------------------------------

# URL of the sim-server (FastAPI on port 8100).
# Default points to the Docker service name; override for local development.
SIM_SERVER_URL=http://localhost:8100

# URL of the inference server (vLLM OpenAI-compatible API).
# INFERENCE_SERVER_URL=http://localhost:8200/v1

# Inference model ID (HuggingFace or local path).
# INFERENCE_MODEL=nvidia/Cosmos-Reason2-2B
