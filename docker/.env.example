# ---------------------------------------------------------------------------
# nvidia-zenith Docker Compose environment variables
# Copy to .env and adjust as needed: cp .env.example .env
# ---------------------------------------------------------------------------

# -- HuggingFace authentication ------------------------------------------------

# Required for gated models (nvidia/Cosmos-Reason2-*).
# Generate at https://huggingface.co/settings/tokens
HF_TOKEN=

# -- Inference model -----------------------------------------------------------

# HuggingFace ID or local path under /models/
# For 2B: nvidia/Cosmos-Reason2-2B
# For 8B: nvidia/Cosmos-Reason2-8B
INFERENCE_MODEL=nvidia/Cosmos-Reason2-2B

# LoRA adapter path inside the container (leave empty to run base model only).
# The host directory adapters/ (project root) is mounted at /adapters/.
# Example: /adapters/cosmos-reason2-8b
LORA_ADAPTER_PATH=

# LoRA model name exposed by vLLM (used for --lora-modules <name>=<path>).
# The app sends requests with this model name when set.
# Must match between inference-server and app-server.
# Example: palletize
LORA_MODEL=

# vLLM configuration
# Minimum 4096 -- the app sends ~1500 input tokens and requests up to 2048
# output tokens. Setting this below 4096 causes 400 errors from vLLM.
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.5
VLLM_REASONING_PARSER=qwen3

# vLLM Docker image -- auto-detected by launch.sh. Override only if needed.
#   x86_64 CUDA 12.x:   vllm/vllm-openai:latest
#   x86_64 CUDA 13.x:   vllm/vllm-openai:latest-cu130   (Blackwell / RTX PRO 1000)
#   Jetson AGX Thor:     nvcr.io/nvidia/vllm:26.01-py3
#   Jetson AGX Orin:     ghcr.io/nvidia-ai-iot/vllm:r36.4-tegra-aarch64-cu126-24.04
# VLLM_IMAGE=vllm/vllm-openai:latest

# -- Model cache ---------------------------------------------------------------

# Bind-mount a host directory as the HuggingFace cache to avoid re-downloading
# models inside the container. Leave commented to use a Docker named volume.
# Example: HF_CACHE_DIR=/home/dr/.cache
# HF_CACHE_DIR=

# -- GPU allocation ------------------------------------------------------------

# GPU device IDs (set different values for multi-GPU production)
SIM_GPU_DEVICE=0
INFERENCE_GPU_DEVICE=0

# -- Service ports -------------------------------------------------------------

SIM_PORT=8100
INFERENCE_PORT=8200
APP_PORT=8000
FRONTEND_PORT=3000

# -- Sim options ---------------------------------------------------------------

SIM_LOAD_ROBOT=true
SIM_SPAWN_BOXES=true

# CUDA base image for sim-server.
# Auto-detected by launch.sh based on host GPU. Override only if needed.
# SIM_CUDA_DEVEL=nvidia/cuda:12.8.0-devel-ubuntu24.04
